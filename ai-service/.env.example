# ─────────────────────────────────────────────────────────────────────────
# ClubHub AI Service — environment configuration
# ─────────────────────────────────────────────────────────────────────────

# Provider for the "prompt → text/json" fallback layer when the custom
# models do not cover the feature (e.g. free-form description drafting).
# Values: "ollama"   → local Ollama daemon (needs Ollama installed)
#         "template" → rules-only, no LLM (always safe, lower quality)
AI_PROVIDER=ollama

# Ollama local server (installed natively on Windows via https://ollama.com/download)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT_SECONDS=120

# When true, /health still reports "ok" even if the upstream LLM is unreachable,
# because we can always fall back to the deterministic template. Keep this on
# for demos.
FALLBACK_ON_LLM_ERROR=true

# ── Custom ML models (your own, trained on club data) ────────────────────
# Toggle the custom scikit-learn recommender and the rule-based PV builder.
# When enabled, the Java backend hits /v1/custom/recommend and /v1/custom/pv
# BEFORE trying the LLM path — so the features work even if Ollama is off.
CUSTOM_MODELS_ENABLED=true

# Optional: path to a pre-trained recommender pickle (joblib). When set and
# readable, the service loads it at boot instead of re-training per request.
# Create it with `python train_recommender.py path/to/events.json`.
CUSTOM_RECOMMENDER_MODEL_PATH=app/custom/models/recommender.pkl

# FastAPI bind
HOST=127.0.0.1
PORT=8000
